{
  "name": "wide-events",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "AGPL-3.0-only",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aboluwade-oluwasegun/wide-events.git"
  },
  "homepage": "https://github.com/aboluwade-oluwasegun/wide-events#readme",
  "bugs": {
    "url": "https://github.com/aboluwade-oluwasegun/wide-events/issues"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "ci": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm --filter @wide-events/internal build && pnpm -r --if-present typecheck",
    "clean": "pnpm -r --if-present clean",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@eslint/js": "^10.0.1",
    "@types/node": "25.5.0",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.57.1",
    "vitest": "4.1.0"
  }
}
